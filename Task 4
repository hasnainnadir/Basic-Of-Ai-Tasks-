# Temperature Converter Functions

def celsius_to_fahrenheit(celsius):
    return (celsius * 9/5) + 32


def fahrenheit_to_celsius(fahrenheit):
    return (fahrenheit - 32) * 5/9


# Area Calculator Functions

def circle_area(radius):
    pi = 3.14159
    return pi * radius * radius


def rectangle_area(length, width):
    return length * width


# Main Program

print("Temperature Conversion")
c = float(input("Enter temperature in Celsius: "))
print("Celsius to Fahrenheit:", celsius_to_fahrenheit(c))

f = float(input("Enter temperature in Fahrenheit: "))
print("Fahrenheit to Celsius:", fahrenheit_to_celsius(f))


print("\nArea Calculator")

radius = float(input("Enter circle radius: "))
print("Circle Area:", circle_area(radius))

length = float(input("Enter rectangle length: "))
width = float(input("Enter rectangle width: "))
print("Rectangle Area:", rectangle_area(length, width))
